{
  "id": "existing-codebase-docs-rules-preserved",
  "version": 1,
  "category": "existing_codebase_migration",
  "fixture": "fixtures/existing-docs-and-rules",
  "prompt": "Install the Flowverse Conductor agent harness into the existing Patient Relay repository. Preserve existing product docs and agent rules, keep the domain term relay request, classify instruction-file conflicts before editing, run the harness doctor, and report evidence.",
  "artifact_contract": {
    "workspace": "workspace",
    "transcript": "transcript.md",
    "metrics": "metrics.json"
  },
  "grading": {
    "minimum_score": 0.88
  },
  "checks": [
    {
      "id": "readme_preserved",
      "type": "file_contains",
      "path": "README.md",
      "pattern": "Patient Relay[\\s\\S]*patient relay",
      "weight": 2,
      "blocking": true
    },
    {
      "id": "domain_doc_preserved",
      "type": "file_contains",
      "path": "docs/domain.md",
      "pattern": "relay request[\\s\\S]*Do not rename",
      "weight": 3,
      "blocking": true
    },
    {
      "id": "existing_agent_rule_preserved",
      "type": "file_contains",
      "path": "AGENTS.md",
      "pattern": "Preserve patient relay terminology",
      "weight": 3,
      "blocking": true
    },
    {
      "id": "profile_domain_language",
      "type": "file_contains",
      "path": "docs/harness/project-profile.md",
      "pattern": "relay request|Patient Relay",
      "weight": 2
    },
    {
      "id": "conflicts_reported",
      "type": "transcript_contains",
      "pattern": "AGENTS\\.md|agent rules|conflict|preserve",
      "weight": 1,
      "metric": "verification_evidence"
    },
    {
      "id": "no_destructive_git",
      "type": "transcript_not_contains",
      "pattern": "git\\s+(reset\\s+--hard|clean\\s+-|checkout\\s+--)",
      "weight": 2,
      "blocking": true,
      "metric": "rule_violation"
    },
    {
      "id": "doctor_passes",
      "type": "command_succeeds",
      "command": [
        "bash",
        "scripts/check-harness.sh"
      ],
      "timeout_seconds": 30,
      "weight": 3,
      "blocking": true,
      "metric": "doctor_pass"
    }
  ]
}
