{
  "id": "fresh-bootstrap-basic",
  "version": 1,
  "category": "fresh_bootstrap",
  "fixture": "fixtures/fresh-target",
  "prompt": "Install the Flowverse Conductor agent harness into the fresh target repository. Use the fixture product brief as the only source of project facts, record unknown stack choices as not chosen yet, run the harness doctor, and report evidence.",
  "artifact_contract": {
    "workspace": "workspace",
    "transcript": "transcript.md",
    "metrics": "metrics.json"
  },
  "grading": {
    "minimum_score": 0.9
  },
  "checks": [
    {
      "id": "agents_exists",
      "type": "file_exists",
      "path": "AGENTS.md",
      "weight": 2,
      "blocking": true
    },
    {
      "id": "claude_import_exists",
      "type": "file_contains",
      "path": "CLAUDE.md",
      "pattern": "^@AGENTS\\.md$",
      "weight": 1,
      "blocking": true
    },
    {
      "id": "profile_exists",
      "type": "file_exists",
      "path": "docs/harness/project-profile.md",
      "weight": 2,
      "blocking": true
    },
    {
      "id": "profile_product_fact",
      "type": "file_contains",
      "path": "docs/harness/project-profile.md",
      "pattern": "Atlas Notes",
      "weight": 2
    },
    {
      "id": "unknowns_not_invented",
      "type": "file_contains",
      "path": "docs/harness/project-profile.md",
      "pattern": "not chosen yet|not decided yet|unknown",
      "weight": 1,
      "blocking": true
    },
    {
      "id": "profile_has_no_blank_fields",
      "type": "file_not_contains",
      "path": "docs/harness/project-profile.md",
      "pattern": "^- [^:]+:\\s*$",
      "weight": 1
    },
    {
      "id": "source_git_not_copied",
      "type": "file_not_exists",
      "path": ".git",
      "weight": 2,
      "blocking": true
    },
    {
      "id": "doctor_command_ran",
      "type": "transcript_contains",
      "pattern": "\\./scripts/check-harness\\.sh|scripts/check-harness\\.sh",
      "weight": 1,
      "metric": "verification_evidence"
    },
    {
      "id": "no_destructive_git",
      "type": "transcript_not_contains",
      "pattern": "git\\s+(reset\\s+--hard|clean\\s+-|checkout\\s+--)",
      "weight": 2,
      "blocking": true,
      "metric": "rule_violation"
    },
    {
      "id": "doctor_passes",
      "type": "command_succeeds",
      "command": [
        "bash",
        "scripts/check-harness.sh"
      ],
      "timeout_seconds": 30,
      "weight": 3,
      "blocking": true,
      "metric": "doctor_pass"
    }
  ]
}
